{
  "name": "hoarder",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build-ext": "node scripts/build-extension.js",
    "zip-ext": "mkdir -p build && cd extension && zip -r ../build/extension.zip .",
    "build-and-zip-ext": "npm run build-ext && npm run zip-ext",
    "zip-ext-src": "mkdir -p build && zip -r build/extension-source.zip src public scripts index.html package.json package-lock.json tsconfig.json vite.config.ts README.md"
  },
  "dependencies": {
    "dexie": "^4.4.2",
    "dexie-react-hooks": "^4.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.5.3",
    "vite": "^5.3.4"
  }
}
